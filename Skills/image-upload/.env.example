# ============================================
# Image Upload & Document Cloudifier Skill Config
# ============================================

# Default provider (imgbb, freeimage, uploadme, imglink)
IMAGE_UPLOAD_PROVIDER=imglink

# ============================================
# ImgBB Configuration
# ============================================
# Get your free API key at: https://api.imgbb.com/
IMGBB_API_KEY=

# ============================================
# Freeimage.host Configuration
# ============================================
# Get your free API key at: https://freeimage.host/page/api
FREEIMAGE_API_KEY=

# ============================================
# UploadMe Configuration (Chevereto, up to 200MB)
# ============================================
# Get your free API key at: https://uploadme.me/settings
UPLOADME_API_KEY=

# ============================================
# ImgLink Configuration (supports SVG, up to 50MB)
# ============================================
# Create an API key at: https://imglink.cc/dashboard
IMGLINK_API_KEY=
